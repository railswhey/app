<%= form_with(model: task_item, url:) do |form| %>
  <% if task_item.errors.any? %>
    <div class="notice warn">
      <strong><%= pluralize(task_item.errors.count, "error") %> prohibited this task item from being saved:</strong>
      <ul>
        <% task_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name, autofocus: true, autocomplete: "off" %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.text_area :description, rows: 3 %>
  </div>

  <div>
    <label style="display: block">Assignee (optional)</label>
    <%= select_tag "task_item[assigned_user_id]",
        options_from_collection_for_select(Current.account.users, "id", "username", task_item.assigned_user_id),
        include_blank: "— Unassigned —",
        id: "assignee-select" %>
    <small>
      <a href="#" onclick="document.getElementById('assignee-select').value='<%= Current.user.id %>';return false;">
        Assign to me (<%= Current.user.username %>)
      </a>
    </small>
  </div>

  <% if action_name.in?(%w[edit update]) %>
    <div>
      <%= form.label :completed, style: "display: block" %>
      <%= form.check_box :completed %>
    </div>
  <% end %>

  <div>
    <%= form.submit %>
    <%= link_to(
      "Cancel",
      task_list_task_items_path(Current.task_list_id, filter: params[:filter]),
      class: "button btn-ghost") %>
  </div>
<% end %>
