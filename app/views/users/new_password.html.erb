<%= render("users/header") %>

<div class="auth-card">
  <h2>Reset your password</h2>
  <p class="auth-subtitle">Enter your email and we'll send you a reset link.</p>

  <%= form_with(model: @user, url: password_users_path) do |f| %>
    <div>
      <%= f.label :email, "Email address" %>
      <%= f.email_field :email, required: true, autofocus: true, autocomplete: "email", placeholder: "you@example.com" %>
    </div>

    <div>
      <%= f.submit "Send reset link →" %>
    </div>
  <% end %>

  <p class="auth-links">
    <%= link_to "← Back to sign in", new_session_users_path %>
  </p>
</div>
