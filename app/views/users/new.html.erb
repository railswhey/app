<%= render("users/header") %>

<div class="auth-card">
  <h2>Create your account</h2>
  <p class="auth-subtitle">Free forever. No credit card required.</p>

  <%= form_with(model: @user, url: users_path) do |f| %>
    <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>
    <% if @user.errors.any? %>
      <div class="notice warn">
        <strong><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</strong>
        <ul>
          <% @user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :username, style: "display: block" %>
      <%= f.text_field :username, required: true, autofocus: true, autocomplete: "username", placeholder: "johndoe" %>
      <small class="auth-hint">3–30 characters. Letters, numbers, and underscores only.</small>
    </div>

    <div>
      <%= f.label :email, "Email address", style: "display: block" %>
      <%= f.email_field :email, required: true, autocomplete: "email", placeholder: "you@example.com" %>
    </div>

    <div>
      <%= f.label :password, style: "display: block" %>
      <%= f.password_field :password, required: true, autocomplete: "new-password", placeholder: "At least 8 characters" %>
      <small class="auth-hint">Minimum 8 characters. Mix letters, numbers and symbols.</small>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm password", style: "display: block" %>
      <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Same again" %>
    </div>

    <div>
      <%= f.submit "Create account →" %>
    </div>
  <% end %>

  <p class="auth-links">
    Already have an account? <%= render("users/sign_in_link") %>
  </p>
</div>
