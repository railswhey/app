<%= render("shared/tasks/header") %>

<%= render("shared/topbar", title: "Invitations", back_path: account_management_path, back_label: "Account") %>

<h2>📨 Invitations</h2>

<% if @invitations.any? %>
  <table>
    <thead>
      <tr>
        <th>Email</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @invitations.each do |invitation| %>
        <tr>
          <td><%= invitation.email %></td>
          <td>
            <span class="chip <%= invitation.accepted? ? 'chip-success' : 'chip-neutral' %>">
              <%= invitation.accepted? ? "accepted" : "pending" %>
            </span>
          </td>
          <td>
            <% if invitation.pending? %>
              <%= link_to "Revoke", account_invitation_path(invitation),
                    data: { turbo_method: :delete, turbo_confirm: "Revoke invitation to #{invitation.email}?" },
                    class: "button btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No invitations yet.</p>
<% end %>

<%= link_to "+ Invite member", new_account_invitation_path, class: "button" %>
