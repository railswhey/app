<%= render("users/header") %>

<div class="auth-card">
  <h2>You're invited! 🎉</h2>
  <p class="auth-subtitle">
    <strong><%= @invitation.invited_by.email %></strong> has invited you to join
    <strong><%= @invitation.account.name %></strong>.
  </p>

  <% if Current.user %>
    <%= form_with url: accept_invitation_path(@invitation.token), method: :patch do %>
      <%= submit_tag "Accept Invitation →" %>
    <% end %>
    <p class="auth-links">
      <%= link_to "← Back to app", root_path %>
    </p>
  <% else %>
    <p class="auth-hint" style="margin-bottom:1rem">Sign in or create an account to accept this invitation.</p>
    <%= link_to "Sign in →", new_session_users_path(return_to: show_invitation_path(@invitation.token)), class: "button", style: "display:block;text-align:center;margin-bottom:0.5rem" %>
    <%= link_to "Create account →", new_user_path, class: "button btn-secondary", style: "display:block;text-align:center" %>
  <% end %>
</div>
