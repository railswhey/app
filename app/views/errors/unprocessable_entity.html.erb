<% content_for :title, "Request Not Accepted — Rails Whey App" %>
<% content_for :body_class, "auth-layout" %>

<% content_for :header do %>
  <header>
    <h1><a href="<%= root_path %>"><%= app_name_with_logo %></a></h1>
    <nav>
      <% if Current.user? %>
        <a href="<%= task_lists_path %>">My Lists</a>
      <% else %>
        <a href="<%= new_session_users_path %>">Sign in</a>
      <% end %>
    </nav>
  </header>
<% end %>

<div class="auth-card" style="text-align:center;">
  <p style="font-size:4.5rem;font-weight:700;color:var(--accent);line-height:1;margin:0 0 0.25rem;">422</p>
  <h2>Request not accepted</h2>
  <p class="auth-subtitle">Something was wrong with your request — this often happens with an expired form. Go back and try again.</p>

  <% if Current.user? %>
    <a href="<%= task_lists_path %>" class="button" style="width:auto;">← Back to My Lists</a>
  <% else %>
    <a href="<%= new_session_users_path %>" class="button" style="width:auto;">← Start over</a>
  <% end %>
</div>
