<%= render("shared/tasks/header") %>

<%= render("shared/topbar", title: "Settings") %>

<h2>Settings</h2>

<div class="settings-hub">
  <%= link_to edit_user_profile_path, class: "card settings-card" do %>
    <div class="settings-card-icon">👤</div>
    <div class="settings-card-body">
      <h3 class="card-title">Profile & Password</h3>
      <p class="card-meta"><%= Current.user.email %></p>
    </div>
    <span class="settings-card-arrow">›</span>
  <% end %>

  <%= link_to edit_user_token_path, class: "card settings-card" do %>
    <div class="settings-card-icon">🔑</div>
    <div class="settings-card-body">
      <h3 class="card-title">API Token</h3>
      <p class="card-meta">CLI access & integrations</p>
    </div>
    <span class="settings-card-arrow">›</span>
  <% end %>

  <%= link_to account_path, class: "card settings-card" do %>
    <div class="settings-card-icon">🏢</div>
    <div class="settings-card-body">
      <h3 class="card-title">Account</h3>
      <p class="card-meta"><%= Current.account&.name || "Account settings" %></p>
    </div>
    <span class="settings-card-arrow">›</span>
  <% end %>
</div>
