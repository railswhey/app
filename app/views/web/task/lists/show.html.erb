<%= render("shared/header") %>

<div id="<%= dom_id(@task_list) %>">
  <%= render("shared/topbar", title: @task_list.name, back_path: task_lists_path, back_label: "Lists") %>

  <div class="action-group">
    <%= link_to("🗂️ View Items", task_list_items_path(@task_list), class: "button btn-secondary") %>
    <% if @task_list.normal? %>
      <%= link_to("✏️ Edit", edit_task_list_path(@task_list), class: "button btn-secondary") %>
      <% if @can_transfer %>
        <%= link_to("↗️ Transfer", new_task_list_transfer_path(@task_list), class: "button btn-secondary") %>
      <% end %>
      <%= link_to(
        "🗑 Delete",
        @task_list,
        data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this task list?" },
        class: "button btn-danger"
      ) %>
    <% end %>
  </div>

  <div class="detail-card">
    <div class="detail-field">
      <span class="detail-label">Name</span>
      <span class="detail-value"><%= @task_list.name %></span>
    </div>
    <% if @task_list.description.present? %>
      <div class="detail-field">
        <span class="detail-label">Description</span>
        <span class="detail-value"><%= @task_list.description %></span>
      </div>
    <% end %>
    <div class="detail-field">
      <span class="detail-label">Created</span>
      <span class="detail-value"><%= @task_list.created_at.strftime("%b %d, %Y at %H:%M") %></span>
    </div>
  </div>

  <%# ── Summary ── %>
  <div class="list-summary">
    <p class="list-summary-heading">📊 Summary</p>

    <div class="summary-stats">
      <div class="summary-stat">
        <span class="summary-stat-value"><%= @stats.total %></span>
        <span class="summary-stat-label">Total</span>
      </div>
      <div class="summary-stat summary-stat--done">
        <span class="summary-stat-value"><%= @stats.done %></span>
        <span class="summary-stat-label">✅ Done</span>
      </div>
      <div class="summary-stat summary-stat--pending">
        <span class="summary-stat-value"><%= @stats.pending %></span>
        <span class="summary-stat-label">⬜ Pending</span>
      </div>
      <div class="summary-stat">
        <span class="summary-stat-value"><%= @stats.assigned %></span>
        <span class="summary-stat-label">👤 Assigned</span>
      </div>
      <div class="summary-stat">
        <span class="summary-stat-value"><%= @stats.comments_count %></span>
        <span class="summary-stat-label">💬 Comments</span>
      </div>
    </div>

    <% if @stats.total > 0 %>
      <div class="summary-progress">
        <div class="progress-bar">
          <div class="progress-fill" style="width: <%= @stats.pct %>%"></div>
        </div>
        <span class="progress-pct"><%= @stats.pct %>% complete</span>
      </div>
    <% end %>

    <div class="summary-meta">
      <span class="summary-meta-activity">🕐 Last activity: <%= time_ago_in_words(@stats.last_activity) %> ago</span>
      <% if @stats.total > 0 && @stats.pending == 0 %>
        <span class="summary-badge summary-badge--done">🎉 All done!</span>
      <% elsif @stats.total > 0 && @stats.done == 0 %>
        <span class="summary-badge summary-badge--pending">🚀 Not started</span>
      <% end %>
    </div>
  </div>

  <%# ── Comments ── %>
  <div class="comments-section">
    <h3 class="comments-heading">
      💬 Comments <span class="comments-count">(<%= @stats.list_comments.size %>)</span>
    </h3>

    <% if @stats.list_comments.any? %>
      <div class="comments-list">
        <% @stats.list_comments.each do |comment| %>
          <%= render "task/shared/comments/comment", comment:, task_list: @task_list, task_item: nil %>
        <% end %>
      </div>
    <% else %>
      <p class="comments-empty">No comments yet. Be the first to leave one.</p>
    <% end %>

    <div class="comment-form-wrap">
      <%= render "task/shared/comments/form",
          comment: Task::Comment.new,
          url: task_list_comments_path(@task_list),
          submit_label: "Add Comment" %>
    </div>
  </div>
</div>
