<%= render("shared/header") %>

<%= render("shared/topbar", title: "Members", back_path: account_management_path, back_label: "Account") %>

<h2>👥 Members</h2>

<table>
  <thead>
    <tr>
      <th>User</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @memberships.each do |membership| %>
      <tr>
        <td>
          <strong><%= membership.person.username %></strong>
          <div><small><%= membership.person.email %></small></div>
        </td>
        <td>
          <span class="chip <%= membership.owner? ? 'chip-success' : 'chip-neutral' %>">
            <%= membership.role %>
          </span>
        </td>
        <td>
          <% unless membership.owner? || membership.person == Current.context.person %>
            <%= link_to "Remove", account_membership_path(membership),
                  data: { turbo_method: :delete, turbo_confirm: "Remove #{membership.person.username}?" },
                  class: "button btn-danger" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
