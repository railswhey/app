<div class="topbar">
  <nav class="topbar-breadcrumb" aria-label="breadcrumb">
    <% if local_assigns[:breadcrumbs] %>
      <% breadcrumbs.each do |crumb| %>
        <%= link_to crumb[:label], crumb[:path] %> <span class="sep">&rsaquo;</span>
      <% end %>
    <% elsif local_assigns[:back_path] && local_assigns[:back_label] %>
      <%= link_to back_label, back_path %> <span class="sep">&rsaquo;</span>
    <% end %>
    <strong><%= title %></strong>
  </nav>
  <div class="topbar-actions">
    <%= link_to "🔍", account_search_path, title: "Search" %>
    <a href="<%= user_settings_path %>" class="topbar-avatar" title="<%= Current.user&.email %>">
      <%= user_initials %>
    </a>
  </div>
</div>
