<% content_for :header do %>
  <header>
    <h1>
      <button class="hamburger" onclick="document.body.classList.toggle('nav-open')" aria-label="Toggle menu">☰</button>
      <a href="<%= home_path %>"><%= app_name_with_logo %></a>
      <span class="mobile-toolbar">
        <%= link_to "🔍", search_path, title: "Search", class: "mobile-toolbar-btn" %>
        <a href="<%= settings_path %>" class="topbar-avatar" title="<%= Current.user&.email %>">
          <%= user_initials %>
        </a>
      </span>
    </h1>

    <nav>
      <details class="account-switcher">
        <summary>🏢 <%= Current.account&.name || "Account" %> ▾</summary>
        <div class="account-menu">
          <% Current.user.accounts.each do |acct| %>
            <% if acct.id == Current.account_id %>
              <span class="account-menu-current">✅ <%= acct.name %></span>
            <% else %>
              <%= link_to "#{acct.name}", account_switches_path(account_id: acct.id), data: { turbo_method: :post } %>
            <% end %>
          <% end %>
          <hr>
          <%= link_to "⚙️ Account settings", account_path %>
        </div>
      </details>

      <hr>

      <%= link_to "🗂️ Items", task_list_task_items_path(Current.task_list_id) %>
      <%= link_to "📋 Lists", task_lists_path %>

      <hr>

      <%= link_to(settings_path) do %>
        <% if current_resource?(controller: "settings") %>
          <strong>⚙️ Settings</strong>
        <% else %>
          ⚙️ Settings
        <% end %>
      <% end %>

      <span class="nav-spacer"></span>

      <%= link_to "👋 Log out", user_sessions_path, data: { turbo_method: :delete }, class: "nav-logout" %>
    </nav>
  </header>
<% end %>
