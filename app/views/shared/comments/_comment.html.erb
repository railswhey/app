<div class="comment" id="<%= dom_id(comment) %>">
  <div class="comment-header">
    <span class="assignee-badge" style="width:1.4rem;height:1.4rem;font-size:0.6rem" title="<%= comment.user.username %>">
      <%= user_initials(comment.user) %>
    </span>
    <strong class="comment-author"><%= comment.user.username %></strong>
    <span class="comment-time"><%= comment.created_at.strftime("%b %-d, %Y · %H:%M") %></span>
    <% if Current.user && comment.user_id == Current.user.id %>
      <span class="comment-actions">
        <% edit_path = task_item.present? ?
            edit_task_list_item_comment_path(task_list, task_item, comment) :
            edit_task_list_comment_path(task_list, comment) %>
        <% delete_path = task_item.present? ?
            task_list_item_comment_path(task_list, task_item, comment) :
            task_list_comment_path(task_list, comment) %>
        <%= link_to "Edit", edit_path, class: "comment-action" %>
        <%= link_to "Delete", delete_path,
            data: { turbo_method: :delete, turbo_confirm: "Delete this comment?" },
            class: "comment-action comment-action--danger" %>
      </span>
    <% end %>
  </div>
  <div class="comment-body"><%= simple_format(comment.body) %></div>
</div>
