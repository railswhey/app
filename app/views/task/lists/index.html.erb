<%= render("shared/tasks/header") %>

<div class="page-title-row">
  <h2>📁 Task Lists</h2>
  <%= link_to("+ New list", new_task_list_path, class: "button btn-secondary") %>
</div>

<% if @task_lists.any? %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @task_lists.each do |task_list| %>
        <tr>
          <td style="width: 100%">
            <%= link_to(task_list.name, task_list_path(task_list)) %>
            <div><small><%= truncate(task_list.description, length: 75) %></small></div>
          </td>
          <td style="text-align:right">
            <select class="action-combo" aria-label="Actions for <%= j(task_list.name) %>"
              onchange="var v=this.value,base='<%= task_list_path(task_list) %>'; this.value='';
                if(v==='details') window.location=base;
                if(v==='items') window.location='<%= task_list_items_path(task_list) %>';
                if(v==='edit') window.location=base+'/edit';
                if(v==='transfer') window.location='<%= new_task_list_transfer_path(task_list) %>';
                if(v==='delete' && confirm('Are you sure you want to delete this task list?')) {
                  var f=document.createElement('form');f.method='POST';f.action=base;
                  var m=document.createElement('input');m.name='_method';m.value='delete';f.appendChild(m);
                  var t=document.createElement('input');t.name='authenticity_token';t.value='<%= j form_authenticity_token %>';f.appendChild(t);
                  document.body.appendChild(f);f.submit(); }">
              <option value="" disabled selected>···</option>
              <option value="details">📋 Details</option>
              <option value="items">👁 View items</option>
              <option value="edit">✏️ Edit</option>
              <% unless task_list.inbox? %>
                <% if Current.account.memberships.owner_or_admin.exists?(user: Current.user) %>
                  <option value="transfer">↗️ Transfer</option>
                <% end %>
                <option value="delete">🗑️ Delete</option>
              <% end %>
            </select>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty-state">
    <div class="empty-state-icon">🗃️</div>
    <h3>No lists yet</h3>
    <p>Lists help you organize tasks by project, context, or area of life.<br>Create your first list to get started.</p>
    <%= link_to "+ Create First List", new_task_list_path, class: "button" %>
  </div>
<% end %>

<div class="tip-box">
  💡 <strong>Tip:</strong> Think of lists like folders — <strong>Work</strong>, <strong>Personal</strong>, <strong>Shopping</strong>.<br>
  Your Inbox is always available for quick captures.
</div>
