<%= render("shared/header") %>

<% all_lists = Current.account.task_lists.order(:name) %>
<% other_lists = all_lists.where.not(id: Current.task_list_id) %>

<div class="topbar" data-controller="modal">
  <nav class="topbar-breadcrumb" aria-label="breadcrumb">
    <a href="#" data-action="modal#open" data-modal-target-param="list-switcher-modal">Lists</a>
    <span class="sep">&rsaquo;</span>
    <strong><%= link_to Current.task_list.name, task_list_path(Current.task_list) %></strong>
  </nav>
  <div class="topbar-actions">
    <%= link_to "🔍", account_search_path, title: "Search" %>
    <a href="<%= user_settings_path %>" class="topbar-avatar" title="<%= Current.user&.email %>">
      <%= user_initials %>
    </a>
  </div>

  <dialog id="list-switcher-modal" data-action="click->modal#backdropClose">
    <div class="modal-header">
      <h3>📋 Switch List</h3>
      <button class="modal-close" data-action="modal#close">✕</button>
    </div>
    <div class="modal-body">
      <% all_lists.each do |tl| %>
        <%= link_to task_list_items_path(tl),
              class: (tl.id == Current.task_list_id ? "active" : nil) do %>
          <%= tl.inbox? ? "📥" : "📋" %> <%= tl.name %>
          <% if tl.id == Current.task_list_id %><small> ← current</small><% end %>
        <% end %>
      <% end %>
    </div>
    <div class="modal-footer">
      <%= link_to "View all lists →", task_lists_path %>
    </div>
  </dialog>
</div>

<% if Current.task_list.task_items.exists? %>
  <p class="filter-tabs"><%= link_to_task_item_filters %></p>

  <% if @task_items.present? %>
    <table>
      <thead>
        <tr>
          <th style="width:1.5rem"></th>
          <th>Name</th>
          <th style="width:2.5rem;text-align:center" title="Assignee">👤</th>
          <th style="text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @task_items.each do |task_item| %>
          <tr style="<%= "opacity:0.7" if task_item.completed? %>">
            <td>
              <% toggle_url = task_item.completed? ?
                  task_list_item_incomplete_path(Current.task_list_id, task_item, filter: params[:filter]) :
                  task_list_item_complete_path(Current.task_list_id, task_item, filter: params[:filter]) %>
              <input type="checkbox" <%= "checked" if task_item.completed? %> class="task-checkbox"
                title="<%= task_item.completed? ? "Mark as incomplete" : "Mark as complete" %>"
                onclick="fetch('<%= toggle_url %>', {method:'PATCH', headers:{'X-CSRF-Token':'<%= j form_authenticity_token %>','Accept':'text/html'}}).then(()=>location.reload())" />
            </td>
            <td style="width:100%">
              <%= link_to task_item.name,
                  task_list_item_path(Current.task_list_id, task_item, filter: params[:filter]),
                  style: task_item.completed? ? "text-decoration:line-through;color:var(--text-light)" : "font-weight:500" %><% if task_item.description.present? %>
                <small class="text-muted"> — <%= truncate(task_item.description, length: 60) %></small><% end %>
            </td>
            <td style="text-align:center">
              <% if task_item.assigned_user %>
                <span class="assignee-badge" title="<%= task_item.assigned_user.username %>">
                  <%= user_initials(task_item.assigned_user) %>
                </span>
              <% else %>
                <span class="assignee-empty" title="Unassigned">○</span>
              <% end %>
            </td>
            <td style="text-align:right">
              <% toggle_path = task_item.completed? ?
                  task_list_item_incomplete_path(Current.task_list_id, task_item, filter: params[:filter]) :
                  task_list_item_complete_path(Current.task_list_id, task_item, filter: params[:filter]) %>
              <select class="action-combo" aria-label="Actions for <%= j(task_item.name) %>"
                onchange="var v=this.value,base='<%= task_list_item_path(Current.task_list_id, task_item, filter: params[:filter]) %>',toggle='<%= toggle_path %>'; this.value='';
                  if(v==='toggle') {
                    var f=document.createElement('form');f.method='POST';f.action=toggle;
                    var m=document.createElement('input');m.name='_method';m.value='patch';f.appendChild(m);
                    var t=document.createElement('input');t.name='authenticity_token';t.value='<%= j form_authenticity_token %>';f.appendChild(t);
                    document.body.appendChild(f);f.submit(); }
                  if(v==='move') { document.getElementById('move-modal-<%= task_item.id %>').showModal(); }
                  if(v==='view') window.location=base;
                  if(v==='edit') window.location=base.replace(/\?.*$/,'')+'/edit<%= "?filter=#{params[:filter]}" if params[:filter].present? %>';
                  if(v==='delete' && confirm('Are you sure you want to delete this task item?')) {
                    var f=document.createElement('form');f.method='POST';f.action=base;
                    var m=document.createElement('input');m.name='_method';m.value='delete';f.appendChild(m);
                    var t=document.createElement('input');t.name='authenticity_token';t.value='<%= j form_authenticity_token %>';f.appendChild(t);
                    document.body.appendChild(f);f.submit(); }">
                <option value="" disabled selected>···</option>
                <option value="toggle"><%= task_item.completed? ? "↩ Mark incomplete" : "✅ Mark complete" %></option>
                <% if other_lists.any? %>
                  <option value="move">📦 Move to…</option>
                <% end %>
                <option value="view">👁 View</option>
                <option value="edit">✏️ Edit</option>
                <option value="delete">🗑️ Delete</option>
              </select>

            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if other_lists.any? %>
      <% @task_items.each do |task_item| %>
        <dialog id="move-modal-<%= task_item.id %>" data-controller="modal" data-action="click->modal#backdropClose">
          <div class="modal-header">
            <h3>📦 Move Task</h3>
            <button class="modal-close" data-action="modal#close">✕</button>
          </div>
          <div class="modal-body">
            <p class="modal-subtitle">Move "<%= truncate(task_item.name, length: 40) %>" to:</p>
            <% other_lists.each do |tl| %>
              <%= link_to task_list_item_moves_path(Current.task_list_id, task_item_id: task_item.id, target_list_id: tl.id),
                    data: { turbo_method: :post } do %>
                <%= tl.inbox? ? "📥" : "📋" %> <%= tl.name %>
              <% end %>
            <% end %>
          </div>
        </dialog>
      <% end %>
    <% end %>
  <% else %>
    <%= empty_task_items_message(params[:filter]) %>
  <% end %>
<% else %>
  <%= empty_task_items_message %>
<% end %>

<% if Current.task_list.task_items.exists? %>
  <%= link_to(
    "+ New item",
    new_task_list_item_path(Current.task_list_id, filter: params[:filter]),
    class: "button btn-secondary",
    style: "width: 100%; text-align: center") %>
<% end %>

<div class="tip-box">
  💡 <strong>Tip:</strong> Use the <strong>Inbox</strong> as your capture zone. Process tasks by moving them to the right list.
</div>
