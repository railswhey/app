<% if current.user %>
  <%= render("shared/header") %>
  <%= render("shared/topbar", title: "Transfer Request") %>
<% end %>

<h2>🔁 List Transfer Request</h2>

<div class="detail-card" style="max-width: 480px;">
  <div class="detail-field">
    <span class="detail-label">List</span>
    <span class="detail-value"><strong><%= @transfer.list.name %></strong></span>
  </div>
  <div class="detail-field">
    <span class="detail-label">From</span>
    <span class="detail-value"><%= @from_account&.name %></span>
  </div>
  <div class="detail-field">
    <span class="detail-label">To</span>
    <span class="detail-value"><%= @to_account&.name %></span>
  </div>
  <div class="detail-field">
    <span class="detail-label">Requested by</span>
    <span class="detail-value"><%= @transfer.initiated_by.email %></span>
  </div>
  <div class="detail-field">
    <span class="detail-label">Status</span>
    <span class="detail-value">
      <span class="chip <%= @transfer.pending? ? 'chip-neutral' : @transfer.accepted? ? 'chip-success' : 'chip-danger' %>">
        <%= @transfer.status %>
      </span>
    </span>
  </div>
  <div class="detail-field">
    <span class="detail-label">Requested</span>
    <span class="detail-value"><%= @transfer.created_at.strftime("%b %d, %Y at %H:%M") %></span>
  </div>
</div>

<% if @transfer.pending? %>
  <% if current.user && @to_account&.owner_or_admin?(current.user) %>
    <div class="action-group" style="max-width: 480px; margin-top: 1rem;">
      <%= link_to "✅ Accept Transfer",
            account_transfers_response_path(token: @transfer.token, action_type: "accept"),
            data: { turbo_method: :patch },
            class: "button" %>
      <%= link_to "❌ Decline",
            account_transfers_response_path(token: @transfer.token, action_type: "reject"),
            data: { turbo_method: :patch },
            class: "button btn-danger" %>
    </div>
  <% elsif !current.user %>
    <div class="card" style="max-width: 480px; margin-top: 1rem;">
      <p>Sign in or create an account to respond to this transfer request.</p>
      <div style="display: flex; gap: 0.75rem; margin-top: 0.5rem;">
        <%= link_to "Sign in →", new_user_session_path(return_to: account_transfers_response_path(token: @transfer.token)), class: "button" %>
        <%= link_to "Create account →", new_user_registration_path(return_to: account_transfers_response_path(token: @transfer.token)), class: "button btn-secondary" %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="card" style="max-width: 480px; margin-top: 1rem;">
    <p>This transfer has been <strong><%= @transfer.status %></strong>.</p>
    <% if current.user %>
      <%= link_to "← Back to Lists", task_lists_path, class: "button btn-secondary", style: "margin-top: 0.5rem;" %>
    <% end %>
  </div>
<% end %>
