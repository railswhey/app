<%= render("shared/header") %>

<%= render("shared/topbar", title: "Profile", back_path: user_settings_path, back_label: "Settings") %>

<h2>User profile</h2>

<div class="card">
  <%= form_with(model: current.user, url: user_settings_profile_path, method: :patch) do |f| %>
    <% if f.object.errors.any? %>
      <div class="notice warn">
        <strong><%= pluralize(f.object.errors.count, "error") %> prohibited this user from being saved:</strong>
        <ul>
          <% f.object.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :email, style: "display: block" %>
      <%= f.email_field :email, disabled: true %>
    </div>

    <div>
      <%= f.label :username, style: "display: block" %>
      <%= f.text_field :username, autocomplete: "username", placeholder: "johndoe" %>
      <small class="auth-hint">3–30 characters. Letters, numbers, and underscores only.</small>
    </div>

    <div>
      <%= f.submit "Update profile" %>
      <%= link_to("Cancel", task_list_items_path(current.task_list_id), class: "button btn-ghost") %>
    </div>
  <% end %>
</div>

<div class="card">
  <%= form_with(url: user_settings_password_path, method: :patch) do |f| %>
    <h3>Change password</h3>

    <div>
      <%= f.label :current_password, "Current password", style: "display: block" %>
      <%= f.password_field :current_password, name: "user[current_password]", required: true %>
    </div>

    <div>
      <%= f.label :password, "New password", style: "display: block" %>
      <%= f.password_field :password, name: "user[password]", required: true %>
    </div>

    <div>
      <%= f.label :password_confirmation, style: "display: block" %>
      <%= f.password_field :password_confirmation, name: "user[password_confirmation]", required: true %>
    </div>

    <div>
      <%= f.submit "Update password" %>
    </div>
  <% end %>
</div>

<div class="danger-zone">
  <h3>Danger Zone</h3>
  <h2>Account deletion</h2>
  <p>
    Deleting your account will permanently remove all of your tasks and lists. This action cannot be undone.
  </p>
  <%= button_to(
    "Delete account",
    user_registration_path,
    method: :delete,
    data: { turbo_confirm: "Are you sure you want to delete your account?" }
  ) %>
</div>
