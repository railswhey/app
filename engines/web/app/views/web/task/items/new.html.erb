<%= render("shared/header") %>

<%= render("shared/topbar",
  title: "New task item",
  breadcrumbs: [
    { label: current.task_list.name, path: task_list_path(current.task_list_id) },
    { label: "Items", path: task_list_items_path(current.task_list_id, filter: params[:filter]) }
  ]) %>

<h2>New task item</h2>

<div class="card">
  <%= render(
    "form",
    task_item: @task_item,
    url: task_list_items_path(current.task_list_id, filter: params[:filter])) %>
</div>
