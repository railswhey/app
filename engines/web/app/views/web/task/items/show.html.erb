<%= render("shared/header") %>

<div id="<%= dom_id(@task_item) %>">
  <%= render("shared/topbar",
    title: @task_item.name,
    breadcrumbs: [
      { label: current.task_list.name, path: task_list_path(current.task_list_id) },
      { label: "Items", path: task_list_items_path(current.task_list_id, filter: params[:filter]) }
    ]) %>

  <div class="action-group">
    <% if @task_item.incomplete? %>
      <%= link_to(
        "✅ Complete",
        task_list_item_complete_path(current.task_list_id, @task_item, filter: "show"),
        title: "Mark as complete",
        data: { turbo_method: :patch },
        class: "button btn-secondary"
      ) %>
    <% else %>
      <%= link_to(
        "↩ Incomplete",
        task_list_item_incomplete_path(current.task_list_id, @task_item, filter: "show"),
        title: "Mark as incomplete",
        data: { turbo_method: :patch },
        class: "button btn-secondary"
      ) %>
    <% end %>
    <%= link_to(
      "✏️ Edit",
      edit_task_list_item_path(current.task_list_id, @task_item, filter: params[:filter]),
      class: "button btn-secondary") %>
    <%= link_to(
      "🗑 Delete",
      task_list_item_path(current.task_list_id, @task_item, filter: params[:filter]),
      data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this task item?" },
      class: "button btn-danger") %>
  </div>

  <div class="detail-card">
    <div class="detail-field">
      <span class="detail-label">Name</span>
      <span class="detail-value"><%= @task_item.name %></span>
    </div>
    <div class="detail-field">
      <span class="detail-label">Status</span>
      <span class="detail-value">
        <span class="chip <%= @task_item.completed? ? "chip-success" : "chip-neutral" %>">
          <%= @task_item.status %>
        </span>
      </span>
    </div>
    <% if @task_item.description.present? %>
      <div class="detail-field">
        <span class="detail-label">Description</span>
        <span class="detail-value"><%= @task_item.description %></span>
      </div>
    <% end %>
    <div class="detail-field">
      <span class="detail-label">Assignee</span>
      <span class="detail-value"><%= @task_item.assigned_member&.username || "—" %></span>
    </div>
    <% if @task_item.completed_at.present? %>
      <div class="detail-field">
        <span class="detail-label">Completed</span>
        <span class="detail-value"><%= @task_item.completed_at.strftime("%b %d, %Y at %H:%M") %></span>
      </div>
    <% end %>
    <div class="detail-field">
      <span class="detail-label">Created</span>
      <span class="detail-value"><%= @task_item.created_at.strftime("%b %d, %Y at %H:%M") %></span>
    </div>
    <div class="detail-field">
      <span class="detail-label">Updated</span>
      <span class="detail-value"><%= @task_item.updated_at.strftime("%b %d, %Y at %H:%M") %></span>
    </div>
  </div>

  <% other_lists = current.task_lists.where.not(id: current.task_list_id) %>
  <% if other_lists.any? %>
    <div class="card">
      <strong>Move to list:</strong>
      <%= form_with url: task_list_item_moves_path(current.task_list_id), method: :post do |f| %>
        <%= hidden_field_tag :task_item_id, @task_item.id %>
        <%= select_tag :target_list_id, options_from_collection_for_select(other_lists, "id", "name") %>
        <%= f.submit "Move" %>
      <% end %>
    </div>
  <% end %>

  <%# ── Comments ── %>
  <% task_list = current.task_list %>
  <% comments = @comments %>
  <div class="comments-section">
    <h3 class="comments-heading">
      💬 Comments <span class="comments-count">(<%= comments.size %>)</span>
    </h3>

    <% if comments.any? %>
      <div class="comments-list">
        <% comments.each do |comment| %>
          <%= render "task/shared/comments/comment", comment:, task_list:, task_item: @task_item %>
        <% end %>
      </div>
    <% else %>
      <p class="comments-empty">No comments yet. Be the first to leave one.</p>
    <% end %>

    <div class="comment-form-wrap">
      <%= render "task/shared/comments/form",
          comment: ::Workspace::Comment.new,
          url: task_list_item_comments_path(task_list, @task_item),
          submit_label: "Add Comment" %>
    </div>
  </div>
</div>
